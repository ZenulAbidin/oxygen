# Base application settings
APP_ENV=local
APP_DEBUG=false
LOGGER_PRETTY=true
LOGGER_LEVEL=info

# Database
DB_DATA_SOURCE=host=postgres sslmode=disable dbname=oxygen user=oxygen password=oxygen pool_max_conns=32
DB_MIGRATE_ON_START=true

# HTTP server / sessions
WEB_PORT=80
SESSION_FS_PATH=/src/tmp/sessions
SESSION_SECRET=session-secret
CORS_ALLOW_ORIGINS=http://localhost:8080

# Payment processing URLs
PROCESSING_WEBHOOK_BASE_PATH=http://localhost:8080
PROCESSING_PAYMENT_FRONTEND_BASE_PATH=http://localhost:8080
PROCESSING_PAYMENT_FRONTEND_SUB_PATH=/p

# Initial email auth user
EMAIL_AUTH_ENABLED=true
EMAIL_AUTH_USER_EMAIL=your.address@gmail.com
EMAIL_AUTH_USER_PASSWORD=<your-password-at-least-8-chars>

# Embedded KMS storage
KMS_DB_DATA_SOURCE=/src/tmp/kms.db

# External providers are optional for local startup.
# Leave these blank to use local fallback rates and disabled webhook subscriptions.
TATUM_API_KEY=
TATUM_TEST_API_KEY=
TATUM_HMAC_SECRET=
TRONGRID_API_KEY=

# Tatum-free payment tracking.
# BTC defaults to Blockstream with mempool.space fallback when left blank.
# If you set a private/custom primary explorer, add fallback URLs explicitly.
# LTC defaults to litecoinspace.org when left blank.
# EVM payment tracking needs JSON-RPC URLs unless Tatum is configured.
CHAIN_BITCOIN_MAINNET_EXPLORER_URL=
CHAIN_BITCOIN_MAINNET_EXPLORER_FALLBACK_URLS=
CHAIN_BITCOIN_TESTNET_EXPLORER_URL=
CHAIN_BITCOIN_TESTNET_EXPLORER_FALLBACK_URLS=
CHAIN_LITECOIN_MAINNET_EXPLORER_URL=
CHAIN_LITECOIN_MAINNET_EXPLORER_FALLBACK_URLS=
CHAIN_LITECOIN_TESTNET_EXPLORER_URL=
CHAIN_LITECOIN_TESTNET_EXPLORER_FALLBACK_URLS=
CHAIN_ETHEREUM_MAINNET_RPC_URL=
CHAIN_ETHEREUM_TESTNET_RPC_URL=
CHAIN_MATIC_MAINNET_RPC_URL=
CHAIN_MATIC_TESTNET_RPC_URL=
CHAIN_BSC_MAINNET_RPC_URL=
CHAIN_BSC_TESTNET_RPC_URL=
CHAIN_EVM_SCAN_BLOCKS=1200
